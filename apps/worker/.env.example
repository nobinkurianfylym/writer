# Redis connection string. BullMQ queues connect here (E5-1).
# Matches the `redis` service in infra/docker/compose.yml.
REDIS_URL=redis://localhost:6379

# Postgres connection string, shared with apps/api.
# Matches the `postgres` service in infra/docker/compose.yml.
DATABASE_URL=postgresql://fylym:fylym@localhost:5432/fylym

# S3-compatible endpoint for export artifacts. MinIO locally, S3 in staging/prod.
# Matches the `minio` service in infra/docker/compose.yml.
S3_ENDPOINT=http://localhost:9000
