# Port the NestJS HTTP server listens on.
PORT=3001

# Postgres connection string. Matches the `postgres` service in
# infra/docker/compose.yml when running `pnpm docker:up` locally.
DATABASE_URL=postgresql://fylym:fylym@localhost:5432/fylym

# Redis connection string, used for rate limiting and (later) BullMQ.
# Matches the `redis` service in infra/docker/compose.yml.
REDIS_URL=redis://localhost:6379

# S3/MinIO for export artifacts + short-lived signed download URLs (E5-1).
# Matches the `minio` service in infra/docker/compose.yml.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=fylym-exports
S3_ACCESS_KEY_ID=fylym
S3_SECRET_ACCESS_KEY=fylym-dev-secret
S3_FORCE_PATH_STYLE=true
SIGNED_URL_TTL_SEC=300
