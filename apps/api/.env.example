# Port the NestJS HTTP server listens on.
PORT=3001

# Postgres connection string. Matches the `postgres` service in
# infra/docker/compose.yml when running `pnpm docker:up` locally.
DATABASE_URL=postgresql://fylym:fylym@localhost:5432/fylym

# Redis connection string, used for rate limiting and (later) BullMQ.
# Matches the `redis` service in infra/docker/compose.yml.
REDIS_URL=redis://localhost:6379
