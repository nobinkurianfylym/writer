{
  "name": "fylym-writer",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "docker:up": "docker compose -f infra/docker/compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/compose.yml down",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:golden": "turbo run test:golden",
    "docs": "turbo run docs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-unknown",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-unknown"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "esbuild": "^0.28.1",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
