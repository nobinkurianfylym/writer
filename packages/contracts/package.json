{
  "name": "@fylym/contracts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm codegen:openapi",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "codegen:openapi": "tsx src/codegen/openapi.ts"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "@asteasolutions/zod-to-openapi": "^7.3.0"
  },
  "devDependencies": {
    "@fylym/config": "workspace:*",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
