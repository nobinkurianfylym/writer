{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts", "src/testing.ts"],
  "out": "docs/api",
  "name": "@fylym/screenplay-core",
  "excludeExternals": true,
  "excludePrivate": true,
  "disableSources": true,
  "treatWarningsAsErrors": true,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": true
  }
}
