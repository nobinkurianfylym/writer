      <DualDialogue>
        <Paragraph Type="Character" FylymDualColumn="left">
          <Text>GUEST 6A</Text>
        </Paragraph>
        <Paragraph Type="Parenthetical" FylymDualColumn="left">
          <Text>laughing</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" FylymDualColumn="left">
          <Text>That&apos;s the 6th time I&apos;ve heard that story.</Text>
        </Paragraph>
        <Paragraph Type="Character" FylymDualColumn="right">
          <Text>GUEST 6B</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" FylymDualColumn="right">
          <Text>Well it&apos;s true every time.</Text>
        </Paragraph>
      </DualDialogue>
    </Paragraph>
    <Paragraph>
      <DualDialogue>
        <Paragraph Type="Character" FylymDualColumn="left">
          <Text>GUEST 7A</Text>
        </Paragraph>
        <Paragraph Type="Dialogue" FylymDualColumn="left">
          <Text>That&apos;s the 7th time I&apos;ve heard that story.</Text>
