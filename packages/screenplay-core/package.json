{
  "name": "@fylym/screenplay-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:golden": "vitest run --dir src/golden",
    "test:golden:report": "vitest run --dir src/golden --reporter=json --reporter=default --outputFile=golden-conformance-report.json",
    "golden:generate": "tsx src/golden/generate.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docs": "typedoc"
  },
  "dependencies": {
    "fast-check": "^3.23.0",
    "fast-xml-parser": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@fylym/config": "workspace:*",
    "eslint": "^9.17.0",
    "tsx": "^4.19.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
