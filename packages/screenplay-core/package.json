{
  "name": "@fylym/screenplay-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:golden": "vitest run --dir src/golden",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "fast-check": "^3.23.0"
  },
  "devDependencies": {
    "@fylym/config": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
